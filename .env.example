# ─────────────────────────────────────────────────────────────────────────────
# Everest Auditor — environment contract
# Copy to .env for local dev. In Railway, set these as service variables.
# NOTHING secret is ever committed (NFR6).
# ─────────────────────────────────────────────────────────────────────────────

# Core
ENV=local                      # local | staging | production
LOG_LEVEL=INFO

# Database (Postgres + pgvector)
DATABASE_URL=postgresql+asyncpg://everest:everest@localhost:5432/everest

# Object storage — Cloudflare R2 (S3-compatible)
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RECORDINGS=everest-recordings
R2_BUCKET_TRANSCRIPTS=everest-transcripts
R2_BUCKET_KB=everest-kb
R2_BUCKET_REPORTS=everest-reports
R2_PRESIGN_TTL_SECONDS=900     # 15 min, short-lived (NFR6)

# AssemblyAI (STT)
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_WEBHOOK_SECRET=
ASSEMBLYAI_BASE_URL=https://api.assemblyai.com
# Public URL of the api service, used for the AssemblyAI webhook callback. When unset
# (local dev), STT falls back to reconciler polling only — no webhook.
PUBLIC_BASE_URL=

# Gemini (LLM judge) — Developer API via google-genai SDK (vertexai=False)
GEMINI_API_KEY=
GEMINI_MODEL_PRIMARY=gemini-3.1-pro-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Auth (OIDC)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
JWT_SECRET=change-me-in-prod

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING & CAPS (NFR3) — every number here is an override-able default.
# Defaults are derived in docs/RATE_LIMITS_AND_COST.md from the reference volume.
# Leave unset to use the in-code defaults (config.py).
# ─────────────────────────────────────────────────────────────────────────────

# --- Gemini guardrails (kept safely under Developer-API tier quotas) ---
# GEMINI_RPM=120
# GEMINI_TPM=1000000
# GEMINI_RPD=8000
# GEMINI_MAX_CONCURRENCY=8

# --- AssemblyAI guardrails ---
# AAI_MAX_INFLIGHT=32           # concurrent in-flight async transcripts
# AAI_RPM=60                    # submission requests/min

# --- Per-portfolio daily cap (calls submitted to transcription/day) ---
# DAILY_CAP_PER_PORTFOLIO=300   # full-volume default; set ~85 for the $100 pilot

# --- Retry / backoff ---
# RETRY_MAX_ATTEMPTS=5
# RETRY_BASE_SECONDS=2.0
# RETRY_CAP_SECONDS=300.0
# RETRY_JITTER_RATIO=0.25

# --- Worker loop ---
# WORKER_CLAIM_BATCH=8
# WORKER_LEASE_SECONDS=300
# WORKER_POLL_INTERVAL_SECONDS=2.0
# RECONCILER_INTERVAL_SECONDS=30
# RECONCILER_TRANSCRIPT_OVERDUE_SECONDS=60

# --- Routing thresholds (judge escalation, §7.3) ---
# ROUTER_CONFIDENCE_THRESHOLD=0.75
# ROUTER_MIN_EVIDENCE_CHARS=24
# ROUTER_MAX_ESCALATION_FRACTION=0.6
